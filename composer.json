{
    "name": "dejwcake/admin-auth",
    "description": "Authentication interface for brackets/admin-ui",
    "license": "MIT",
    "type": "library",
    "keywords": [
        "auth",
        "authentication",
        "login",
        "user",
        "admin",
        "cms",
        "laravel"
    ],
    "authors": [
        {
            "name": "David Běhal",
            "email": "david.behal@dejw.sk",
            "homepage": "https://www.dejw.sk",
            "role": "Developer"
        },
        {
            "name": "Pavol Perdík",
            "email": "pavol.perdik@brackets.sk",
            "homepage": "https://www.brackets.sk",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.5",
        "dejwcake/admin-ui": "^2.0",
        "dejwcake/craftable-media": "^2.0",
        "illuminate/support": "^13.0",
        "spatie/laravel-permission": "^7.4"
    },
    "require-dev": {
        "larastan/larastan": "^3.9",
        "orchestra/testbench": "^11.1",
        "phpunit/phpunit": "^13.1"
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "autoload": {
        "psr-4": {
            "Brackets\\AdminAuth\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Brackets\\AdminAuth\\Tests\\": "tests/"
        }
    },
    "extra": {
        "branch-alias": {
            "dev-main": "2.0-dev",
            "dev-v2-dev": "2.0-dev"
        },
        "laravel": {
            "providers": [
                "Brackets\\AdminAuth\\AdminAuthServiceProvider"
            ]
        }
    }
}
